__pycache__/
*.pyc
.venv/
venv/
output/
*.zip
coverage.xml
.coverage
.pytest_cache/
.ruff_cache/
.hypothesis/
.DS_Store

# Knowledge-graph artefacts (graphify) — regenerated locally, never published.
graphify-out/

# Internal/private dev artefacts — audit findings, /simplify assessments, and
# hardening/refactor/release plans. Never publish to GitHub.
AUDIT_FINDINGS*.md
*-assessment-*.md
*_PLAN.md
*.local.md

# Local-only investigation artefacts: HA logs, diagnostics dumps, live-deploy
# captures. Treat as sensitive (may contain tokens, MACs, internal hostnames,
# credentials in tracebacks). Do not commit. Keep the folder placeholder so
# tooling can write here without first creating the dir.
docs/internal/*
!docs/internal/.gitkeep

# .claude/ — gitignored by default, with explicit re-includes for team-shared
# Claude Code config (settings.json, hooks, commands, agents, skills).
# Personal/runtime state stays ignored (settings.local.json, scheduled_tasks.lock,
# worktrees/, etc.). See ADR-010.
#
# To share a new .claude/<dir>/ contents with the team, add TWO lines:
#     !.claude/<dir>/
#     !.claude/<dir>/**
# (the first un-ignores the directory entry, the second un-ignores its contents)
.claude/*
!.claude/settings.json
!.claude/hooks/
!.claude/hooks/*.sh
!.claude/commands/
!.claude/commands/*.md
!.claude/agents/
!.claude/agents/*.md
!.claude/skills/
!.claude/skills/**
